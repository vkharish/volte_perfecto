# Copy this file to .env and fill in your values
# Never commit .env to source control

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Perfecto API Gateway — used by agent.py / run_skill.py (CI/CD + skill execution)
PERFECTO_API_URL=https://api.yourcompany.com/perfecto
PERFECTO_TOKEN=your-perfecto-token

# Perfecto MCP Server — used by Claude Code for ad-hoc interactive lab use
# PERFECTO_CLOUD_NAME is your subdomain (e.g. "mylab" from mylab.perfectomobile.com)
PERFECTO_CLOUD_NAME=your-cloud-name
PERFECTO_SECURITY_TOKEN=your-perfecto-security-token
